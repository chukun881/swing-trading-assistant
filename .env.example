# Swing Trading Assistant - 环境变量配置
# 复制此文件为 .env 并填入你的 API Key

# ============================================================================
# Telegram Bot 配置
# ============================================================================
# 1. 在 Telegram 中找到 @BotFather
# 2. 发送 /newbot 创建新机器人
# 3. 复制 Bot Token 并填入下方
TELEGRAM_BOT_TOKEN=your_bot_token_here

# 1. 在 Telegram 中发送消息给你的机器人
# 2. 访问 https://api.telegram.org/bot<your_token>/getUpdates
# 3. 找到 "chat":{"id":123456789} 中的数字
# 4. 复制 Chat ID 并填入下方
TELEGRAM_CHAT_ID=your_chat_id_here

# ============================================================================
# IBKR 配置 (可选 - 用于 Portfolio Tracking)
# ============================================================================
# 如果你想连接 Interactive Brokers 账户进行实际交易
IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=1